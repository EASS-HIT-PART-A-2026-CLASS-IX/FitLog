# ── Required ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars

# Get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./fitlog.db

# ── Redis (for background tasks) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# Comma-separated origins (no spaces)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Docker deployment ─────────────────────────────────────────────────────────
# Public URL of the API — must be reachable from users' browsers.
# Local Docker: leave as default (http://localhost:8000)
# Remote server: set to your server's IP or domain, e.g. http://1.2.3.4:8000
PUBLIC_API_BASE=http://localhost:8000

# ── AI / Groq ─────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_ANALYTICS=300
CACHE_TTL_FOOD_ANALYSIS=86400
